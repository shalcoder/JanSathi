# AWS Configuration
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=ap-south-1  # JanSathi is India-focused (Mumbai region)

# S3 Bucket for Audio Storage
S3_BUCKET_NAME=jansathi-audio-bucket-XXXXXXXX

# Bedrock Configuration
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# Bedrock Knowledge Base Configuration (PDF Upload + Intelligent Caching)
BEDROCK_KB_ID=XXXXXXXXXX                           # Your Knowledge Base ID from AWS Console
BEDROCK_KB_S3_BUCKET=jansathi-kb-bucket            # S3 bucket for PDF storage
BEDROCK_KB_MODEL_ARN=arn:aws:bedrock:us-east-1::foundation-model/anthropic.claude-3-sonnet-20240229-v1:0
KB_CACHE_TTL=86400                                 # Cache TTL in seconds (24 hours default)
KB_ENABLE_CACHE=true                               # Enable intelligent caching for cost savings

# Kendra (DISABLED - Using Mock RAG to save costs)
KENDRA_INDEX_ID=mock-index

# Flask Configuration
SECRET_KEY=change-this-to-a-random-secret-key
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Database
DATABASE_URL=sqlite:///jansathi.db
USE_DYNAMODB=true
DYNAMODB_USERS_TABLE=JanSathi-Users

# Layer 7: SNS Notifications
SNS_TOPIC_ARN=arn:aws:sns:ap-south-1:123456789012:JanSathi-Notifications

# Rate Limiting
RATELIMIT_DEFAULT=200 per day
RATELIMIT_STORAGE_URL=memory://

# Port
PORT=5000
